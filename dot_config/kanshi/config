# -----------------
# Private profiles
# -----------------
profile notebook {
  output $NOTEBOOK enable
  exec notify-send --app-name kanshi 'Kanshi' 'Applied profile: notebook'
}

profile home {
  output $NOTEBOOK disable
  output $HOME_LEFT enable
  output $HOME_MAIN enable
  output $HOME_RIGHT enable
  exec swaymsg workspace 11, move workspace to output '"BNQ BenQ RL2460H S2G01438SL0"'
  exec swaymsg workspace 12, move workspace to output '"BNQ BenQ RL2460H J7F06731SL0"'
  exec notify-send --app-name kanshi 'Kanshi' 'Applied profile: home'
}

profile kueki {
  output $NOTEBOOK disable
  output $KUEKI_1 enable
  exec notify-send --app-name kanshi 'Kanshi' 'Applied profile: kueki'
}

