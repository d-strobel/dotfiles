output "Acer Technologies XB253Q TH5EE00B8521" {
  mode 1920x1080@60.0
  position 1920,0
  scale 1
  alias $HOME_MAIN
}
output "BNQ BenQ RL2460H J7F06731SL0" {
  mode 1920x1080@60.0
  position 3840,0
  scale 1
